# Flask Configuration
FLASK_APP=wsgi
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
AUTO_CREATE_TABLES=0
RUN_MIGRATIONS=0
RATELIMIT_STORAGE_URI=memory://

# Database (PostgreSQL required – set DATABASE_URL to your Neon/Postgres connection string)
# Example (replace <password> with your actual password):
# DATABASE_URL=postgresql://user:<password>@host/dbname?sslmode=require

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API Configuration
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-4o-mini

# Market Data API
GOLD_API_KEY=your-goldapi-key-here

# OTP / Email settings (Gmail SMTP)
# Set DISABLE_EMAIL_OTP=true to skip OTP verification entirely (auto-verify users on register).
# Useful on Render/production when Gmail SMTP is not configured.
# WARNING: Keep DISABLE_EMAIL_OTP=false in production for proper security.
DISABLE_EMAIL_OTP=false
# Set OTP_DEV_MODE=true to print the OTP to the console instead of sending email.
# WARNING: NEVER enable OTP_DEV_MODE in production. OTP will NOT be shown on-screen
# even if this is set, but it will be logged to the console. Keep it false in production.
OTP_DEV_MODE=false
# Gmail SMTP credentials (required when DISABLE_EMAIL_OTP=false and OTP_DEV_MODE=false)
# Use a Gmail App Password (not your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
# MAIL_USERNAME=yourgmail@gmail.com
# MAIL_PASSWORD=your_app_password

