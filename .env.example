# Flask Configuration
FLASK_APP=wsgi
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
AUTO_CREATE_TABLES=0
RUN_MIGRATIONS=0
RATELIMIT_STORAGE_URI=memory://

# Database (PostgreSQL required – set DATABASE_URL to your Neon/Postgres connection string)
# Example (replace <password> with your actual password):
# DATABASE_URL=postgresql://user:<password>@host/dbname?sslmode=require

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API Configuration
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-4o-mini

# Market Data API
# Primary gold price provider (https://www.goldapi.io)
GOLD_API_KEY=your-goldapi-key-here
# Fallback gold price provider (https://metalpriceapi.com) — used automatically when GoldAPI fails
METALPRICE_API_KEY=your-metalpriceapi-key-here

# OTP / Email settings (Google Apps Script)
# OTP emails are delivered via Google Apps Script Web App — no SMTP credentials needed.
# Set DISABLE_EMAIL_OTP=true to skip OTP verification entirely (auto-verify users on register).
# Useful for local testing when you don't need email delivery.
# WARNING: Keep DISABLE_EMAIL_OTP=false in production for proper security.
DISABLE_EMAIL_OTP=false
# Set OTP_DEV_MODE=true to print the OTP to the console instead of calling the Apps Script API.
# WARNING: NEVER enable OTP_DEV_MODE in production.
OTP_DEV_MODE=false

# Google OAuth (optional – enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URIs in the Google Cloud Console:
#   - Local:      http://localhost:5000/auth/google/callback
#   - Production: https://<your-app>.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Set to your production callback URL when deploying (leave unset for local dev default)
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/google/callback

