# Flask Configuration
FLASK_APP=wsgi
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
AUTO_CREATE_TABLES=0
RUN_MIGRATIONS=0
RATELIMIT_STORAGE_URI=memory://

# Database (PostgreSQL required – set DATABASE_URL to your Neon/Postgres connection string)
# Example (replace <password> with your actual password):
# DATABASE_URL=postgresql://user:<password>@host/dbname?sslmode=require

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API Configuration
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-4o-mini

# Market Data API
GOLD_API_KEY=your-goldapi-key-here

# OTP / Email settings (Google Apps Script)
# OTP emails are delivered via Google Apps Script Web App — no SMTP credentials needed.
# Set DISABLE_EMAIL_OTP=true to skip OTP verification entirely (auto-verify users on register).
# Useful for local testing when you don't need email delivery.
# WARNING: Keep DISABLE_EMAIL_OTP=false in production for proper security.
DISABLE_EMAIL_OTP=false
# Set OTP_DEV_MODE=true to print the OTP to the console instead of calling the Apps Script API.
# WARNING: NEVER enable OTP_DEV_MODE in production.
OTP_DEV_MODE=false

